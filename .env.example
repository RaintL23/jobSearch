# --- Google Gemini (obligatorio) ---
# Clave de API de Google AI Studio / Gemini
GOOGLE_API_KEY=tu_api_key_aqui

# Modelos Gemini en orden de preferencia (separados por coma).
# Si el primero agota su cuota (429 RESOURCE_EXHAUSTED), el motor prueba
# automáticamente el siguiente de la lista sin que el usuario tenga que hacer nada.
# Todos los modelos "lite" / "flash" son gratuitos en Google AI Studio free tier.
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-1.5-flash-8b,gemini-3.1-flash-lite

# Modelo único de respaldo (solo se usa si GEMINI_MODELS está vacío o no existe)
GEMINI_MODEL=gemini-3.1-flash-lite

# --- País por defecto (opcional) ---
# Código ISO2 usado cuando el perfil no indica país (mx, co, ar, pe, cl, ...).
# DEFAULT_COUNTRY es el nombre nuevo; COMPUTRABAJO_COUNTRY sigue funcionando.
DEFAULT_COUNTRY=ar

# --- Ajustes avanzados (opcionales; se muestran los valores por defecto) ---
# Timeout de cada llamada a Gemini, en segundos.
# AI_REQUEST_TIMEOUT_SEC=60
# Máximo de caracteres del CV enviados al modelo.
# AI_MAX_CV_CHARS=12000
# Tope de seguridad de ofertas por búsqueda (todas las fuentes).
# SCRAPE_SAFETY_CAP=70
# Tope de ofertas por fuente de API pública.
# PER_SOURCE_CAP=12
# Timeout de las APIs HTTP públicas, en segundos.
# HTTP_TIMEOUT_SEC=25
# Puerto de depuración remota del navegador para importar sesión del sistema.
# BROWSER_CDP_PORT=9222
# Segundos para completar el login interactivo.
# LOGIN_TIMEOUT_SEC=600
# Override de tasas de cambio a USD (JSON). Ej: {"ars": 0.0009, "brl": 0.19}
# FX_RATES_JSON=
